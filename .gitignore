*.py[cod]
*$py.class
.venv/
venv/
env/
.python-version
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ---- Node / frontend ----
node_modules/
dist/
.vite/
*.local
.eslintcache

