# ============================================================================
#  SchoolAutomaton — environment configuration. Copy to .env and fill in.
#  Everything with a sane default can be left unset for local dev.
# ============================================================================

# ---- Provider credentials (REQUIRED for generation to work) ----
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_TOKEN=r8_...

# ---- Secrets (REQUIRED in production) ----
# APP_SECRET: master secret. Used to derive the JWT signing key and the Fernet
# key that encrypts API keys / flagged raw audit text at rest. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET=change-me-please-a-long-random-string

# ---- Bootstrap admin (created on first boot if no admin exists) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-too

# ---- Models (override only if needed) ----
SA_MODEL_ID=claude-opus-4-8
SA_SANITIZER_MODEL_ID=claude-haiku-4-5

# ---- Runtime ----
SA_ENV=development                 # development | production
SA_DEBUG=true
SA_DATABASE_URL=sqlite+aiosqlite:///./data/schoolautomaton.db
SA_DATA_DIR=./data
SA_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ---- Safety / audit ----
SA_RAW_CAPTURE_ON_FLAG=false       # retain Fernet-encrypted raw text ONLY for safety-flagged events
SA_AUDIT_RAW_RETENTION_DAYS=30

# ---- Rate limiting (per profile/ip) ----
SA_RATE_PER_MIN=20
SA_RATE_PER_DAY=300

# ---- Cost guardrails ----
SA_VIDEO_ENABLED=false             # opt-in Replicate image-to-video (quota-gated, off by default)
SA_DAILY_VIDEO_QUOTA=0

# ---- Frontend (used by Vite at build/dev) ----
VITE_API_BASE=/api/v1
